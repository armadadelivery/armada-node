{
  "name": "@armada/sdk",
  "version": "0.1.0-beta.0",
  "description": "Official Armada Automated Ordering API v2 SDK for Node.js / TypeScript.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/armadadelivery/armada-node.git"
  },
  "homepage": "https://github.com/armadadelivery/armada-node#readme",
  "bugs": {
    "url": "https://github.com/armadadelivery/armada-node/issues"
  },
  "keywords": [
    "armada",
    "armada-delivery",
    "automated-ordering",
    "delivery-api",
    "sdk"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  }
}
